# Copy to .env and adjust as needed. All values have safe defaults in app/core/config.py.

# Full path to the LaTeX engine.
#   macOS (BasicTeX, this project): /usr/local/texlive/2026basic/bin/universal-darwin/pdflatex
#   Docker/Linux: usually just "pdflatex" (on PATH) — see DEPLOYMENT.md
PDFLATEX_PATH=/usr/local/texlive/2026basic/bin/universal-darwin/pdflatex

# Max seconds a single compile may run before being killed.
COMPILE_TIMEOUT=20

# Reject LaTeX source larger than this many bytes.
MAX_CODE_BYTES=1000000

# Comma/JSON list of browser origins allowed to call the API (React dev servers).
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# --- AI layer (see LLM.md) ---------------------------------------------------
# OpenAI API key. Server-side ONLY. Required for /match and /generate.
# Leave blank to boot without AI; AI endpoints will return a clear error.
OPENAI_API_KEY=

# Model names per tier. Override here if you switch models.
GEN_MODEL=gpt-5
# Match tier auto-picks by input size: small -> mini, large -> full (LLM.md §5).
GAP_MODEL_SMALL=gpt-4.1-mini
GAP_MODEL_LARGE=gpt-4.1
GAP_TOKEN_THRESHOLD=6000

# Match gate: score >= this unlocks generation; below only advises.
MATCH_THRESHOLD=70

# Verify & repair loop caps.
MAX_REPAIR_RETRIES=2
MAX_TOTAL_MODEL_CALLS=6

# --- Accounts & database (multi-user) ----------------------------------------
# Postgres connection string (e.g. Neon). Required for auth/profile/dashboard.
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# JWT auth. Generate a strong secret: python -c "import secrets; print(secrets.token_urlsafe(48))"
# MUST be set to a private random value in production.
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRE_MINUTES=10080
